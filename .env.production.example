# Продакшен-окружение для eotinish.kaztbu.edu.kz.
# Скопируйте в .env на сервере и заполните секреты. НИКОГДА не коммитьте .env.

# Безопасность — сгенерируйте: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=
COOKIE_SECURE=true

# Инфраструктура (имена сервисов из docker-compose)
DB_PASSWORD=
DATABASE_URL=postgresql+asyncpg://ncaip_user:${DB_PASSWORD}@postgres:5432/ncaip_db
REDIS_URL=redis://redis:6379/0

# Anthropic
ANTHROPIC_API_KEY=
AGENT_MODEL=claude-haiku-4-5

# Публичный адрес платформы (OAuth redirect, ссылки)
PUBLIC_BASE_URL=https://eotinish.kaztbu.edu.kz
CORS_ORIGINS=["https://eotinish.kaztbu.edu.kz"]

# Файлы
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_MB=10

# Seed-пароли в продакшене НЕ задавать (демо-данные не загружать)
SEED_ADMIN_PASSWORD=
SEED_ANALYST_PASSWORD=
SEED_OPERATOR_PASSWORD=
SEED_STUDENT_PASSWORD=
SEED_TEACHER_PASSWORD=
SEED_EMPLOYEE_PASSWORD=
