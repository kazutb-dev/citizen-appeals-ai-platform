# ===== MedHubHAQ — AI-платформа обращений граждан в сфере здравоохранения =====
# Скопируйте в .env и заполните реальными значениями. Файл .env НИКОГДА не коммитится.
# В репозитории не должно быть реальных паролей и ключей.

# --- База данных ---
# Сгенерировать: python -c "import secrets; print(secrets.token_urlsafe(24))"
DB_PASSWORD=replace-with-strong-password
DATABASE_URL=postgresql+asyncpg://ncaip_user:${DB_PASSWORD}@postgres:5432/ncaip_db

# --- Redis (очередь arq) ---
REDIS_URL=redis://redis:6379/0

# --- Безопасность ---
# Сгенерировать: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=

# --- LLM-провайдер (ТОЛЬКО локальный инференс; облачные API запрещены) ---
# ollama | vllm (vllm совместим и с llama.cpp server)
LLM_PROVIDER=ollama
# По умолчанию — сервис ollama из docker-compose. Для Ollama на хосте:
# http://host.docker.internal:11434 (Docker) или http://localhost:11434 (локально)
LLM_BASE_URL=http://ollama:11434
# Модель RU/KK: qwen2.5:7b-instruct | qwen2.5:14b-instruct | gemma2:9b | aya-expanse:8b
LLM_LOCAL_MODEL=qwen2.5:7b-instruct

# --- Embeddings (локально, sentence-transformers) ---
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024
VECTOR_DB=pgvector

# --- Reranker (bge-reranker-v2-m3) ---
RERANKER_ENABLED=true
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# --- CORS (dev-фронтенд) ---
CORS_ORIGINS=["http://localhost:5173","http://localhost"]
VITE_ENVIRONMENT=development

# --- Яндекс Карты (для RegionalMap) ---
YANDEX_JAVASCRIPT_API_KEY=
VITE_YANDEX_API_KEY=

# --- Публичный адрес ---
PUBLIC_BASE_URL=http://localhost

# --- Пароли demo-аккаунтов (LOCAL DEMO ONLY — не использовать в продакшене) ---
# admin@medhubhaq.kz (role=admin)
SEED_ADMIN_PASSWORD=
# analyst@medhubhaq.kz (role=analyst)
SEED_ANALYST_PASSWORD=
# operator@medhubhaq.kz (role=operator)
SEED_OPERATOR_PASSWORD=
# patient@medhubhaq.kz (role=requester/patient)
SEED_PATIENT_PASSWORD=
# doctor@medhubhaq.kz (role=requester/medical_worker)
SEED_DOCTOR_PASSWORD=
# nurse@medhubhaq.kz (role=requester/medical_worker)
SEED_NURSE_PASSWORD=

